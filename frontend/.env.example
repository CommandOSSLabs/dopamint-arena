# tunnel-manager backend base URL — control-plane (ADR-0002) + PvP /v1/mp (ADR-0004).
# The browser calls this cross-origin; the backend serves CORS headers (main.rs), so point
# it straight at the ALB. Leave EMPTY only for a same-origin deploy (frontend behind the
# same host as the backend). Deploy the CORS-enabled backend build before relying on this.
VITE_BACKEND_URL=http://dopamint-dev-alb-0fac7e0-1152788681.us-east-1.elb.amazonaws.com
# Deployed sui_tunnel package on testnet (the create_and_fund-capable build).
VITE_TUNNEL_PACKAGE_ID=0x0b89fe86e42cdbfd1e614757a83d014b455d12923d0dded58842ab18f8a5a22b

# --- Sui network (the games' on-chain bots read this). If VITE_SUI_NETWORK is unset the
#     clients fall back to the public testnet fullnode below, but set it to be explicit. ---
VITE_SUI_NETWORK="https://fullnode.testnet.sui.io:443"
VITE_SUI_NETWORK_NAME="testnet"
# Tic-Tac-Toe reads its own package-id var (same deployed package as the tunnel above).
# Without it, ttt bot mode can't open/fund a tunnel.
VITE_TTT_PACKAGE_ID=0x0b89fe86e42cdbfd1e614757a83d014b455d12923d0dded58842ab18f8a5a22b

# --- zkLogin sign-in (Enoki + Google). PUBLIC client identifiers, safe to ship. Both are
#     required for the "Sign in with Google" entry to appear in the connect modal.
#     The Enoki public key must be a TESTNET zkLogin key (matches the testnet network above).
#     The app's origin must be allow-listed BOTH in the Google OAuth client's "Authorized
#     JavaScript origins" (e.g. http://localhost:5173 for dev + the prod domain) AND in the
#     Enoki Portal app config — otherwise the Google popup fails. ---
VITE_ENOKI_API_KEY="enoki_public_c2637950de9eb2076182026ab9db9980"
VITE_GOOGLE_CLIENT_ID="541088436204-bj7ancgngnr4nn3msaqtdvatek1j7itn.apps.googleusercontent.com"

# --- MTPS free-faucet stake token (ADR-0010). Games stake MTPS instead of SUI; gas stays
#     sponsored in SUI. All three required to enable the MTPS stake path (else games fall back
#     to SUI stakes). The faucet mints on demand, so it never runs out. Deployed on testnet. ---
VITE_MTPS_PACKAGE_ID=0xe4184df2487b81757b4473a527595443599bd00204e1e1ed5b7ab63cbcb7f703
VITE_MTPS_FAUCET_ID=0xae50a0a9155a0f08b67b23244ac50e8494032050283825d6a99a70027ee9010d
VITE_MTPS_COIN_TYPE=0xe4184df2487b81757b4473a527595443599bd00204e1e1ed5b7ab63cbcb7f703::mtps::MTPS
# Backend base for stats/live; use the same host as VITE_BACKEND_URL for a deployed backend.
VITE_API_URL=http://dopamint-dev-alb-0fac7e0-1152788681.us-east-1.elb.amazonaws.com
