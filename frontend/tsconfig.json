{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "useDefineForClassFields": true,
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "verbatimModuleSyntax": false,
    "isolatedModules": true,
    "skipLibCheck": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "types": ["node"],
    "paths": {
      "@/*": ["./src/*"],
      "sui-tunnel-ts": ["../sui-tunnel-ts/src/index.ts"],
      "sui-tunnel-ts/*": ["../sui-tunnel-ts/src/*"],
      "@ttt/shared": ["./src/games/ticTacToe/packages/shared/src/index.ts"],
      "@ttt/shared/*": ["./src/games/ticTacToe/packages/shared/src/*"]
    }
  },
  "include": ["src"],
  "exclude": [
    "src/games/*/packages",
    "src/**/*.test.ts",
    "src/games/blackjack/app/main.tsx",
    "src/games/ticTacToe/app/main.tsx"
  ]
}
