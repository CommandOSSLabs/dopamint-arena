{
  "name": "frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Dopamint Arena frontend shell — wallet-gated desktop of self-playing tunnel games",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test \"src/components/**/*.test.ts\" \"src/backend/**/*.test.ts\" \"src/games/blackjack/*.test.ts\"",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\""
  },
  "dependencies": {
    "@mysten/dapp-kit": "^1.1.0",
    "@mysten/sui": "^2.18.0",
    "@mysten/wallet-standard": "^0.21.0",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-router": "^1.170.16",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "gsap": "^3.15.0",
    "lucide-react": "^1.20.0",
    "radix-ui": "^1.6.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-resizable-panels": "^4.11.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "playwright": "^1.61.0",
    "prettier": "^3.8.4",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.22.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  }
}
