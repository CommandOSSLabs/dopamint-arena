# tunnel-manager (DOP-170) — see docs/decisions/0002-backend-client-api-contract.md
TUNNEL_MANAGER_ADDR=0.0.0.0:8080
RUST_LOG=info,tower_http=debug

# Sui (required from Phase 1 onward; optional in Phase 0)
SUI_RPC_URL=https://fullnode.testnet.sui.io:443
# Network for Enoki sponsorship (testnet/mainnet/devnet). MUST match ENOKI_API_KEY's network.
# Keep testnet: the settler fallback's chain digest is testnet-pinned (ADR-0014).
SUI_NETWORK=testnet
TUNNEL_PACKAGE_ID=0x0b89fe86e42cdbfd1e614757a83d014b455d12923d0dded58842ab18f8a5a22b
# Stake coin type. MTPS is the free stake token games stake; the sponsor pins tunnel calls + the
# close payout to this type. Gas is still paid in SUI by the settler. Set 0x2::sui::SUI to stake SUI.
TUNNEL_COIN_TYPE=0xe0f8eae320959eb7300cb599a6e7a287355c60b299a7e80a808d9196e0aea8ea::mtps::MTPS
# base64 ed25519 secret of the gas/settler account. MUST hold SUI (the SIP-58 gas source); it
# needs NO MTPS (the faucet mints that). `sui keytool export … | sui keytool convert` -> base64.
# With the faucet (below), this is also the MTPS mint key — it must own the AdminCap.
SUI_SETTLER_KEY=

# MTPS faucet (ADR-0015). The backend signs `admin_mint` with SUI_SETTLER_KEY, which must own the
# AdminCap (= the deploy key — see docs/runbooks/mtps-deploy.md). Unset MTPS_ADMIN_CAP_ID disables
# both faucet routes (503). Amounts are whole tokens (0 decimals).
MTPS_ADMIN_CAP_ID=0x7cc2d628c6ceeefb1e48502b0900eac5bc77f2dd9d170bdc339053e38b03ceae
# Public faucet: whole-token MTPS per pull, rate-limited to MAX pulls per WINDOW per address.
FAUCET_USER_AMOUNT=10000
FAUCET_COOLDOWN_SECS=1800
FAUCET_MAX_PER_WINDOW=5
# Internal faucet: default mint amount (caps at the contract's MAX_MINT_PER_CALL = 1,000,000).
FAUCET_INTERNAL_AMOUNT=1000000
# Shared bearer secret gating POST /v1/faucet/internal. Unset = internal route disabled (503).
FAUCET_ADMIN_TOKEN=

# Enoki sponsored transactions (ADR-0014): the PRIMARY gas sponsor; the settler above is the
# fallback. The PRIVATE key (`enoki_private_…`) from the Enoki portal — server-side ONLY, distinct
# from the frontend's PUBLIC VITE_ENOKI_API_KEY (zkLogin). Leave blank here and set the real key in
# the gitignored .env. Unset = settler-only. The Enoki app must allowlist the tunnel/coin/example
# packages for the configured SUI_NETWORK, else every sponsor falls back to the settler.
ENOKI_API_KEY=

# Walrus (required from Phase 2 onward)
WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space
WALRUS_AGGREGATOR_URL=https://aggregator.walrus-testnet.walrus.space

# Ollama LLM proxy (chat-v2)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:1.5b

# Slim example-app packages — sponsored when set (agent allowance, streaming payment).
AGENT_ALLOWANCE_PACKAGE_ID=0x36d982ffdcf89c709829650bd6b07128f505f41d8953f48658746291d5bfb679
STREAMING_PAYMENT_PACKAGE_ID=0x5125f1e0b65ba5c27cc5eb130ee34133bf55ddc30322cf7099d748f4df23e7ea

# Redis (local dev). Both must be set together (cache + pubsub) or startup fails loud.
REDIS_CACHE_URL=redis://127.0.0.1:6379
REDIS_PUBSUB_URL=redis://127.0.0.1:6379
