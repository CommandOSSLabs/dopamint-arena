# tunnel-manager (DOP-170) — see docs/decisions/0002-backend-client-api-contract.md
TUNNEL_MANAGER_ADDR=0.0.0.0:8080
RUST_LOG=info,tower_http=debug

# Sui (required from Phase 1 onward; optional in Phase 0)
SUI_RPC_URL=http://127.0.0.1:9000
TUNNEL_PACKAGE_ID=0x...        # published sui_tunnel package id
TUNNEL_COIN_TYPE=0x2::sui::SUI
SUI_SETTLER_KEY=               # base64 ed25519 secret key of the gas/settler account (Phase 1)

# Walrus (required from Phase 2 onward)
WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space
WALRUS_AGGREGATOR_URL=https://aggregator.walrus-testnet.walrus.space
