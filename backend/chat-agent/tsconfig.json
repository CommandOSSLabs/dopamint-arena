{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "baseUrl": ".",
    "paths": {
      "sui-tunnel-ts": ["../../sui-tunnel-ts/src/index.ts"],
      "sui-tunnel-ts/*": ["../../sui-tunnel-ts/src/*.ts"]
    }
  },
  "include": ["src"]
}
