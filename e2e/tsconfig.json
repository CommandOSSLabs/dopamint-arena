{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2023"],
    "types": ["node"],
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@mysten/sui/client": ["./harness/sui-client-shim.ts"],
      "@mysten/sui": ["./node_modules/@mysten/sui"],
      "@mysten/sui/*": ["./node_modules/@mysten/sui/*"],
      "sui-tunnel-ts": ["../sui-tunnel-ts/src/index.ts"],
      "sui-tunnel-ts/*": ["../sui-tunnel-ts/src/*"]
    }
  },
  "include": ["src/**/*.ts", "harness/**/*.ts", "loader/**/*.mjs"]
}
