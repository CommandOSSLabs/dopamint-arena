{
  "name": "dopamint-infra",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc --noEmit",
    "test": "node --test dist/**/*.test.js",
    "preview": "pulumi preview",
    "up": "pulumi up -y",
    "destroy": "pulumi destroy -y",
    "output": "pulumi stack output --json > output.json"
  },
  "dependencies": {
    "@pulumi/aws": "^7.29.0",
    "@pulumi/awsx": "^3.5.0",
    "@pulumi/pulumi": "^3.243.0",
    "@pulumi/random": "^4.21.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.9.0"
  }
}
